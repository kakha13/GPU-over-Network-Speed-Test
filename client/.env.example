# Copy to .env and edit. For LAN testing only weak passwords are fine.
REDIS_PASSWORD=lantest
MINIO_USER=admin
MINIO_PASSWORD=lantest123

# Set to the LAN IP of THIS machine (the Linux box running docker compose).
# Find it with: ip -4 addr show | grep inet
# Example: http://192.168.1.50:9000
# This must be the IP that the Windows machine can reach on your LAN.
S3_PUBLIC_ENDPOINT=http://192.168.1.50:9000
