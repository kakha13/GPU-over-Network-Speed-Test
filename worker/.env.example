# Copy to .env and edit

# LAN IP of the Linux machine running the client docker-compose stack.
# Find it on the Linux box with: ip -4 addr show | grep inet
# Example: 192.168.1.50
SERVER_HOST=192.168.1.105

# Must match what's in client/.env (these are weak on purpose for LAN testing)
REDIS_PASSWORD=lantest
MINIO_USER=admin
MINIO_PASSWORD=lantest123
